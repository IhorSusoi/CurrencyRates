@page "/"
@using CurrencyRates.Client.Services
@inject CurrencyRates.Client.Services.CurrencyRatesApiClient ApiClient

<PageTitle>Курси валют НБУ</PageTitle>

<h3 style="text-align: center; font-size: clamp(1.1rem, 4vw, 1.75rem); margin-bottom: 16px;">
    Курси валют НБУ
</h3>

<RadzenStack Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap"
             AlignItems="AlignItems.End" JustifyContent="JustifyContent.Center"
             Gap="12px" Style="margin-bottom: 24px;">
    <RadzenStack Gap="4px">
        <RadzenText TextStyle="TextStyle.Body2" Text="Дата дії курсу" />
        <RadzenDatePicker @bind-Value="this.selectedDate"
                          DateFormat="yyyy-MM-dd"
                          Style="width: 100%; min-width: 180px; max-width: 240px;" />
    </RadzenStack>

    <RadzenButton Text="Показати"
                  Icon="search"
                  Click="this.LoadRatesAsync"
                  Disabled="this.isLoading" />
</RadzenStack>

@if (this.isLoading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}

@if (this.errorMessage is not null)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true">
        @this.errorMessage
    </RadzenAlert>
}

@if (this.rates is not null)
{
    @if (this.rates.Count == 0)
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">
            Немає даних на вибрану дату.
        </RadzenAlert>
    }
    else
    {
        <div style="overflow-x: auto; -webkit-overflow-scrolling: touch;">
            <RadzenDataGrid Data="this.rates" TItem="CurrencyRateModel"
                            AllowSorting="true" Density="Density.Compact">
                <Columns>
                    <RadzenDataGridColumn TItem="CurrencyRateModel"
                                          Property="CurrencyCode"
                                          Title="Валюта"
                                          MinWidth="80px" />

                    <RadzenDataGridColumn TItem="CurrencyRateModel"
                                          Property="CurrencyName"
                                          Title="Назва валюти"
                                          MinWidth="150px" />

                    <RadzenDataGridColumn TItem="CurrencyRateModel"
                                          Property="Rate"
                                          Title="Курс (UAH)"
                                          MinWidth="100px"
                                          FormatString="{0:F4}" />

                    <RadzenDataGridColumn TItem="CurrencyRateModel"
                                          Property="RateDate"
                                          Title="Дата дії курсу"
                                          MinWidth="120px"
                                          FormatString="{0:yyyy-MM-dd}" />

                    <RadzenDataGridColumn TItem="CurrencyRateModel"
                                          Property="Source"
                                          Title="Джерело"
                                          MinWidth="80px" />

                    <RadzenDataGridColumn TItem="CurrencyRateModel"
                                          Property="CreatedAt"
                                          Title="Завантажено в БД"
                                          MinWidth="160px"
                                          FormatString="{0:yyyy-MM-dd HH:mm:ss}" />
                </Columns>
            </RadzenDataGrid>
        </div>
    }
}

@code {
    private DateTime selectedDate = DateTime.Today;
    private List<CurrencyRateModel>? rates;
    private bool isLoading;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await this.LoadRatesAsync();
    }

    private async Task LoadRatesAsync()
    {
        this.isLoading = true;
        this.errorMessage = null;
        this.rates = null;

        var date = DateOnly.FromDateTime(this.selectedDate);
        var (result, error) = await this.ApiClient.GetRatesAsync(date);

        this.rates = result;
        this.errorMessage = error;
        this.isLoading = false;
    }
}
